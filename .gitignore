# ---------------------------------------------------------------
[Dd]ebug/
[Rr]elease/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# ---------------------------------------------------------------
# NuGet packages
# Uncomment the line below if you store NuGet packages in the repo.
# ---------------------------------------------------------------
CLAUDE_API/packages/
*.nupkg
*.snupkg
.nuget/

# ---------------------------------------------------------------
# ASP.NET / IIS
# ---------------------------------------------------------------
App_Data/
PublishOutput/

# ---------------------------------------------------------------
# Web.config sensitive transforms
# Keep the base Web.config but exclude environment-specific secrets.
# ---------------------------------------------------------------
# Uncomment if you use user secrets or local overrides:
# Web.config

# ---------------------------------------------------------------
# Compiled output & symbols
# ---------------------------------------------------------------
*.dll
*.exe
*.pdb
*.cache
*.ilk
*.meta
*.obj
*.iobj
*.ipdb
*.pgc
*.pgd
*.rsp
*.sbr
*.tlb
*.tlh
*.tmp
*.tmp_proj
*_wpftmp.csproj
*.log
*.tlog
*.vspscc
*.vssscc

# ---------------------------------------------------------------
# Roslyn / Code analysis
# ---------------------------------------------------------------
*.AnalyzerReference

# ---------------------------------------------------------------
# Test results
# ---------------------------------------------------------------
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
*.VisualState.xml
TestResult.xml
nunit-*.xml

# ---------------------------------------------------------------
# ASP.NET Scaffolding
# ---------------------------------------------------------------
ScaffoldingReadMe.txt

# ---------------------------------------------------------------
# Windows
# ---------------------------------------------------------------
Thumbs.db
Thumbs.db:encryptionKey
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# ---------------------------------------------------------------
# macOS (if collaborating cross-platform)
# ---------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
._*

# ---------------------------------------------------------------
# JetBrains Rider / ReSharper
# ---------------------------------------------------------------
.idea/
*.sln.iml
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# ---------------------------------------------------------------
# Node / npm (if any front-end tooling is added)
# ---------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---------------------------------------------------------------
# Environment / secrets (never commit these!)
# ---------------------------------------------------------------
.env
.env.local
.env.*.local
secrets.json
appsettings.Development.json
