# =============================================================
# .gitattributes for Claude_Course_Hinal — ASP.NET MVC 5
# =============================================================
# Enforce consistent line endings and binary handling across
# Windows, macOS, and Linux collaborators.
# =============================================================

# ---------------------------------------------------------------
# Default behaviour: auto-detect text files and normalise to LF
# in the repository; check out with the platform's native endings.
# ---------------------------------------------------------------
* text=auto eol=lf

# ---------------------------------------------------------------
# Windows scripts — must use CRLF on checkout
# ---------------------------------------------------------------
*.bat        text eol=crlf
*.cmd        text eol=crlf
*.ps1        text eol=crlf

# ---------------------------------------------------------------
# Source code — always LF
# ---------------------------------------------------------------
*.cs         text eol=lf diff=csharp
*.cshtml     text eol=lf diff=html
*.razor      text eol=lf diff=html
*.vb         text eol=lf
*.fs         text eol=lf
*.fsx        text eol=lf

# ---------------------------------------------------------------
# Web assets
# ---------------------------------------------------------------
*.html       text eol=lf diff=html
*.htm        text eol=lf diff=html
*.css        text eol=lf diff=css
*.js         text eol=lf diff=javascript
*.ts         text eol=lf diff=javascript
*.jsx        text eol=lf diff=javascript
*.tsx        text eol=lf diff=javascript
*.json       text eol=lf
*.xml        text eol=lf diff=xml
*.config     text eol=lf diff=xml
*.xsd        text eol=lf diff=xml
*.xslt       text eol=lf diff=xml
*.resx       text eol=lf diff=xml
*.svg        text eol=lf diff=xml

# ---------------------------------------------------------------
# Project / solution files
# ---------------------------------------------------------------
*.csproj     text eol=lf diff=xml
*.vbproj     text eol=lf diff=xml
*.fsproj     text eol=lf diff=xml
*.sln        text eol=crlf
*.props      text eol=lf diff=xml
*.targets    text eol=lf diff=xml
*.nuspec     text eol=lf diff=xml

# ---------------------------------------------------------------
# Documentation & markdown
# ---------------------------------------------------------------
*.md         text eol=lf diff=markdown
*.txt        text eol=lf
*.rst        text eol=lf
*.yml        text eol=lf
*.yaml       text eol=lf

# ---------------------------------------------------------------
# Shell scripts
# ---------------------------------------------------------------
*.sh         text eol=lf
*.bash       text eol=lf

# ---------------------------------------------------------------
# Binary files — never apply text diff or newline conversion
# ---------------------------------------------------------------
*.png        binary
*.jpg        binary
*.jpeg       binary
*.gif        binary
*.ico        binary
*.webp       binary
*.bmp        binary
*.tiff       binary
*.svg        text eol=lf diff=xml

*.woff       binary
*.woff2      binary
*.ttf        binary
*.eot        binary
*.otf        binary

*.pdf        binary
*.zip        binary
*.gz         binary
*.tar        binary
*.7z         binary
*.rar        binary

*.dll        binary
*.exe        binary
*.pdb        binary
*.lib        binary

*.mp3        binary
*.mp4        binary
*.wav        binary
*.ogg        binary
*.avi        binary
*.mov        binary

# ---------------------------------------------------------------
# GitHub / Git LFS hints (uncomment if using Git LFS)
# ---------------------------------------------------------------
# *.png  filter=lfs diff=lfs merge=lfs -text
# *.jpg  filter=lfs diff=lfs merge=lfs -text

# ---------------------------------------------------------------
# Linguist overrides (for GitHub language detection)
# ---------------------------------------------------------------
# Exclude generated/vendor files from language stats
CLAUDE_API/packages/** linguist-vendored
CLAUDE_API/bin/**       linguist-generated
CLAUDE_API/obj/**       linguist-generated
*.min.js                linguist-generated
*.min.css               linguist-generated
