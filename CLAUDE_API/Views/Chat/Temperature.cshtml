@{
    ViewBag.Title = "Task 3 - Temperature";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@Html.Partial("_ChatNav")

<div class="chat-wrapper">
    <h2>Task 3 - Temperature Control</h2>
    <p style="text-align:center; color:#888; font-size:13px; margin-bottom:12px;">
        0.0 = same answer every time &nbsp;|&nbsp; 1.0 = creative and varied
    </p>

    <div class="ctrl-bar blue">
        <label>SYSTEM</label>
        <input type="text" id="systemPromptInput"
               placeholder="e.g. You are a creative movie director" />
    </div>

    <div class="ctrl-bar blue">
        <div class="temp-row">
            <label>TEMPERATURE</label>
            <input type="range" id="tempSlider" min="0.0" max="1.0" step="0.1" value="1.0"
                   oninput="updateTemp(this.value)" />
            <span class="temp-val" id="tempDisplay">1.0</span>
        </div>
        <div class="temp-hints">
            <span>0.0 Deterministic</span>
            <span>1.0 Creative</span>
        </div>
    </div>

    <div class="chat-box" id="chatBox">
        <div class="empty-msg" id="emptyMsg">
            Drag the slider, then ask "Generate a one sentence movie idea"
        </div>
    </div>

    <div id="typing-indicator" style="display:none; color:#888; font-size:13px; padding:6px 0;">
        Claude is typing...
    </div>

    <div class="input-area">
        <textarea id="userInput" placeholder="Try: Generate a one sentence movie idea"></textarea>
        <button class="btn-send" id="sendBtn">Send</button>
    </div>

    <button class="btn-clear" id="clearBtn">Clear conversation</button>
</div>

<script>
    var chatHistory = [];

    function updateTemp(val) {
        document.getElementById("tempDisplay").innerText = parseFloat(val).toFixed(1);
    }

    function appendBubble(role, text) {
        var emptyMsg = document.getElementById("emptyMsg");
        if (emptyMsg) emptyMsg.remove();

        var wrap = document.createElement("div");
        wrap.className = "bubble-wrap " + role;

        var lbl = document.createElement("div");
        lbl.className = "lbl";
        lbl.innerText = role === "user" ? "You" : "Claude";

        var msg = document.createElement("div");
        msg.className = "message " + role;
        msg.innerText = text;

        wrap.appendChild(lbl);
        wrap.appendChild(msg);
        document.getElementById("chatBox").appendChild(wrap);
        document.getElementById("chatBox").scrollTop = 9999;
    }

    document.getElementById("sendBtn").addEventListener("click", sendMessage);

    document.getElementById("userInput").addEventListener("keydown", function (e) {
        if (e.key === "Enter" && !e.shiftKey) {
            e.preventDefault();
            sendMessage();
        }
    });

    function sendMessage() {
        var input = document.getElementById("userInput").value.trim();
        var systemPrompt = document.getElementById("systemPromptInput").value.trim();
        var temperature = parseFloat(document.getElementById("tempSlider").value);
        if (!input) return;

        appendBubble("user", input);
        chatHistory.push({ role: "user", content: input });
        document.getElementById("userInput").value = "";
        document.getElementById("typing-indicator").style.display = "block";
        document.getElementById("sendBtn").disabled = true;

        fetch("/Chat/SendTemperature", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ messages: chatHistory, systemPrompt: systemPrompt, temperature: temperature })
        })
        .then(function (res) { return res.json(); })
        .then(function (data) {
            document.getElementById("typing-indicator").style.display = "none";
            document.getElementById("sendBtn").disabled = false;
            if (data.success) {
                appendBubble("assistant", data.text);
                chatHistory.push({ role: "assistant", content: data.text });
            } else {
                appendBubble("assistant", "Error: " + data.error);
            }
        })
        .catch(function () {
            document.getElementById("typing-indicator").style.display = "none";
            document.getElementById("sendBtn").disabled = false;
            appendBubble("assistant", "Request failed.");
        });
    }

    document.getElementById("clearBtn").addEventListener("click", function () {
        chatHistory = [];
        document.getElementById("chatBox").innerHTML =
            '<div class="empty-msg" id="emptyMsg">Drag the slider, then ask "Generate a one sentence movie idea"</div>';
    });
</script>
