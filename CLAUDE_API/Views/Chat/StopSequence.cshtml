@{
    ViewBag.Title = "Task 5 - Stop Sequence";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@Html.Partial("_ChatNav")

<div class="chat-wrapper">
    <h2>Task 5 - Stop Sequence</h2>
    <p style="text-align:center; color:#888; font-size:13px; margin-bottom:12px;">
        Claude will stop generating when it hits the stop sequence you define.
    </p>

    <div class="ctrl-bar blue">
        <label>YOUR PROMPT</label>
        <textarea id="userPrompt" rows="3"
                  placeholder="e.g. Generate three different sample AWS CLI commands">Generate three different sample AWS CLI commands. Each should be very short.</textarea>
    </div>

    <div class="ctrl-bar blue">
        <label>PREFILL (optional)</label>
        <input type="text" id="prefillText"
               value="Here are all three commands in a single block without any comments:&#10;```bash"
               placeholder="e.g. ```bash" />
    </div>

    <div class="ctrl-bar blue">
        <label>STOP SEQUENCES (comma separated)</label>
        <input type="text" id="stopSeqs" value="```"
               placeholder="e.g. ```" />
    </div>

    <div style="margin: 10px 0;">
        <button class="btn-send" id="sendBtn">Send</button>
    </div>

    <div id="typing-indicator" style="display:none; color:#888; font-size:13px; padding:6px 0;">
        Claude is typing...
    </div>

    <pre id="output"
         style="min-height:120px; background:#1e1e1e; color:#d4d4d4;
                padding:14px; border-radius:6px; white-space:pre-wrap;
                font-size:13px; margin-top:10px;"></pre>

    <button class="btn-clear" id="clearBtn">Clear output</button>
</div>

<script>
    document.getElementById("sendBtn").addEventListener("click", sendMessage);

    function sendMessage() {
        var prompt = document.getElementById("userPrompt").value.trim();
        if (!prompt) return;

        var output = document.getElementById("output");
        output.textContent = "";
        document.getElementById("typing-indicator").style.display = "block";
        document.getElementById("sendBtn").disabled = true;

        var stopRaw = document.getElementById("stopSeqs").value.trim();
        var stops = stopRaw ? stopRaw.split(",").map(function (s) { return s.trim(); }) : [];

        fetch("/Chat/SendStopSequence", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
                messages: [{ role: "user", content: prompt }],
                prefill: document.getElementById("prefillText").value,
                stopSequences: stops,
                temperature: 1.0
            })
        })
        .then(function (res) { return res.json(); })
        .then(function (data) {
            document.getElementById("typing-indicator").style.display = "none";
            document.getElementById("sendBtn").disabled = false;
            output.textContent = data.success ? data.text : "Error: " + data.error;
        })
        .catch(function () {
            document.getElementById("typing-indicator").style.display = "none";
            document.getElementById("sendBtn").disabled = false;
            output.textContent = "Request failed.";
        });
    }

    document.getElementById("clearBtn").addEventListener("click", function () {
        document.getElementById("output").textContent = "";
        document.getElementById("userPrompt").value = "";
    });
</script>
